    tPays                TPays                 @relation(fields: [paysOrigine], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tRegimesDeclarations TRegimesDeclarations? @relation(fields: [regimeDeclaration], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tUtilisateurs        TUtilisateurs         @relation(fields: [session], references: [id])
    tNotesDetail         TNotesDetail[]

