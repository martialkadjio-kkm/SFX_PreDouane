    session      Int      @map("Session")
    dateCreation DateTime @map("Date Creation")
    rowVer       Bytes?   @map("RowVer")

    tUtilisateurs   TUtilisateurs     @relation(fields: [session], references: [id])
    tEtapesDossiers TEtapesDossiers[]

    @@map("TCodesEtapes")
}

/// Folder statuses
model TStatutsDossier {
    id                   Int      @id @default(autoincrement()) @map("ID Statut Dossier")
    libelleStatutDossier String   @unique @map("Libelle Statut Dossier") @db.NVarChar(200)
    session              Int      @map("Session")
    dateCreation         DateTime @map("Date Creation")
    rowVer               Bytes?   @map("RowVer")

    tUtilisateurs TUtilisateurs @relation(fields: [session], references: [id])
    tDossiers     TDossiers[]

    @@map("TStatutsDossier")
