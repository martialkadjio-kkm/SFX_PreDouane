    prixUnitaireColis   Decimal  @default(0) @map("Prix Unitaire Colis") @db.Decimal(24, 2)
    poidsBrut           Decimal  @default(0) @map("Poids Brut") @db.Decimal(24, 6)
    poidsNet            Decimal  @default(0) @map("Poids Net") @db.Decimal(24, 3)
    volume              Decimal  @default(0) @map("Volume") @db.Decimal(24, 3)
    ajustementValeur    Decimal  @default(0) @map("Ajustement Valeur") @db.Decimal(24, 2)
    paysOrigine         Int      @map("Pays Origine")
