/// Folder stages/workflow steps
model TEtapesDossiers {
    id           Int       @id @default(autoincrement()) @map("ID Etape Dossier")
    dossier      Int       @map("Dossier")
    etapeDossier Int       @map("Etape Dossier")
    dateDebut    DateTime  @map("Date Debut")
    dateFin      DateTime? @map("Date Fin")
    reference    String?   @map("Reference") @db.NVarChar(200)
    qte          Decimal   @default(0) @map("Qte") @db.Decimal(24, 6)
    obs          String?   @map("Obs") @db.NVarChar(1000)
    session      Int       @map("Session")
    dateCreation DateTime  @map("Date Creation")
    rowVer       Bytes?    @map("RowVer")

    tDossiers     TDossiers     @relation(fields: [dossier], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tCodesEtapes  TCodesEtapes  @relation(fields: [etapeDossier], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tUtilisateurs TUtilisateurs @relation(fields: [session], references: [id])

    @@map("TEtapesDossiers")
}

/// Stage definitions
