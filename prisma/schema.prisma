/// Folder types combining sense of traffic and transport mode
model TTypesDossiers {
    id            Int      @id @default(autoincrement()) @map("ID Type Dossier")
    libelle       String   @unique @map("Libelle Type Dossier") @db.NVarChar(200)
    sensTrafic    String   @map("Sens Trafic") @db.NVarChar(1)
    modeTransport String   @map("Mode Transport") @db.NVarChar(1)
    entite        Int      @map("Entite")
    session       Int      @map("Session")
    dateCreation  DateTime @map("Date Creation")
    rowVer        Bytes?   @map("RowVer")

    tSensTrafic     TSensTrafic     @relation(fields: [sensTrafic], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tModesTransport TModesTransport @relation(fields: [modeTransport], references: [id])
    tDossiers       TDossiers[]

    @@map("TTypesDossiers")
}

/// System users
model TUtilisateurs {
    id              Int      @id @default(autoincrement()) @map("ID Utilisateur")
    codeUtilisateur String   @unique @map("Code Utilisateur") @db.NVarChar(10)
    nomUtilisateur  String   @unique @map("Nom Utilisateur") @db.NVarChar(200)
    entite          Int      @map("Entite")
    session         Int      @map("Session")
    dateCreation    DateTime @map("Date Creation")
    rowVer          Bytes?   @map("RowVer")

    tSessions            TSessions[]
    tDossiers            TDossiers[]
    tColisageDossiers    TColisageDossiers[]
    tNotesDetail         TNotesDetail[]
    tEtapesDossiers      TEtapesDossiers[]
    tConvertions         TConvertions[]
    tTauxChange          TTauxChange[]
    tPermissonsRoles     TPermissonsRoles[]
    tRegimesClients      TRegimesClients[]
    tRegimesDeclarations TRegimesDeclarations[]
    tCodesEtapes         TCodesEtapes[]
    tStatutsDossier      TStatutsDossier[]
    tRoles               TRoles[]
    tPermissionsBase     TPermissionsBase[]
    tDevises             TDevises[]
    tGroupesEntites      TGroupesEntites[]
    tEntites             TEntites[]
    tBranches            TBranches[]
    tClients             TClients[]
    tRegimesDouaniers    TRegimesDouaniers[]
    tpays                TPays[]
    trolesUtilisateurs   TRolesUtilisateurs[]

    @@map("TUtilisateurs")
}

/// User session tracking for audit
model TSessions {
    id           Int      @id @default(autoincrement()) @map("ID Session")
    utilisateur  Int      @map("Utilisateur")
    debutSession DateTime @map("Debut Session")
    finSession   DateTime @map("Fin Session")
    rowVer       Bytes?   @map("RowVer")

    user TUtilisateurs @relation(fields: [utilisateur], references: [id], onUpdate: Cascade)

    @@map("TSessions")
}

model TSensTrafic {
    id           String   @id @map("ID Sens Trafic") @db.NVarChar(1)
    libelle      String   @unique @map("Libelle Sens Trafic") @db.NVarChar(200)
    session      Int      @map("Session")
    dateCreation DateTime @map("Date Creation")
    rowVer       Bytes?   @map("RowVer")

    tTypesDossiers TTypesDossiers[]

    @@map("TSensTrafic")
}

model TModesTransport {
    id           String   @id @map("ID Mode Transport") @db.NVarChar(1)
    libelle      String   @unique @map("Libelle Mode Transport") @db.NVarChar(200)
    session      Int      @map("Session")
    dateCreation DateTime @map("Date Creation")
    rowVer       Bytes?   @map("RowVer")

    tTypesDossiers TTypesDossiers[]

    @@map("TModesTransport")
}

/// Currency conversion dates per entity
model TConvertions {
    id             Int      @id @default(autoincrement()) @map("ID Convertion")
    dateConvertion DateTime @unique @map("Date Convertion")
    entite         Int      @map("Entite")
    session        Int      @map("Session")
    dateCreation   DateTime @map("Date Creation")
    rowVer         Bytes?   @map("RowVer")

    tEntites      TEntites      @relation(fields: [entite], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tUtilisateurs TUtilisateurs @relation(fields: [session], references: [id])
    tTauxChange   TTauxChange[]
    tDossiers     TDossiers[]

    @@map("TConvertions")
}

/// Customers
model TClients {
    id           Int      @id @default(autoincrement()) @map("ID Client")
    nomClient    String   @unique @map("Nom Client") @db.NVarChar(200)
    entite       Int      @map("Entite")
    session      Int      @map("Session")
    dateCreation DateTime @map("Date Creation")
    rowVer       Bytes?   @map("RowVer")

    tEntites        TEntites          @relation(fields: [entite], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tUtilisateurs   TUtilisateurs     @relation(fields: [session], references: [id])
    tDossiers       TDossiers[]
    tRegimesClients TRegimesClients[]

    @@map("TClients")
}

/// Folders (transit orders)
model TDossiers {
    id                   Int      @id @default(autoincrement()) @map("ID Dossier")
    branche              Int      @map("Branche")
    typeDossier          Int      @map("Type Dossier")
    client               Int      @map("Client")
    descriptionDossier   String   @map("Description Dossier") @db.NVarChar(1000)
    noOT                 String   @map("No OT") @db.NVarChar(100)
    noDossier            String   @map("No Dossier") @db.NVarChar(50)
    nbrePaquetageOT      Int      @map("Nbre Paquetage Pesee")
    poidsBrutPesee       Decimal  @default(0) @map("Poids Brut Pesee") @db.Decimal(24, 6)
    poidsNetPesee        Decimal  @default(0) @map("Poids Net Pesee") @db.Decimal(24, 6)
    volumePesee          Decimal  @default(0) @map("Volume Pesee") @db.Decimal(24, 6)
    responsableDossier   Int      @map("Responsable Dossier")
    convertion           Int?     @map("Convertion")
    deviseNoteDetail     Int?     @map("Devise Note Detail")
    derniereEtapeDossier Int?     @map("Derniere Etape Dossier")
    observationDossier   String?  @map("Observation Dossier") @db.NVarChar(1000)
    statutDossier        Int      @map("Statut Dossier")
    session              Int      @map("Session")
    dateCreation         DateTime @map("Date Creation")
    rowVer               Bytes?   @map("RowVer")

    tBranches         TBranches           @relation(fields: [branche], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tTypesDossiers    TTypesDossiers      @relation(fields: [typeDossier], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tClients          TClients            @relation(fields: [client], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tUtilisateurs     TUtilisateurs       @relation(fields: [responsableDossier], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tConvertions      TConvertions?       @relation(fields: [convertion], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tStatutsDossier   TStatutsDossier     @relation(fields: [statutDossier], references: [id])
    tColisageDossiers TColisageDossiers[]
    tEtapesDossiers   TEtapesDossiers[]

    @@unique([noDossier, branche], name: "UQ_TDossiers_No_Dossier")
    @@unique([noOT, client], name: "UQ_TDossiers_No_OT")
    @@map("TDossiers")
}

/// Currencies
model TDevises {
    id             Int      @id @default(autoincrement()) @map("ID Devise")
    codeDevise     String   @unique @map("Code Devise") @db.NVarChar(5)
    libelleDevise  String   @unique @map("Libelle Devise") @db.NVarChar(200)
    decimales      Int      @map("Decimales")
    deviseInactive Boolean  @default(false) @map("Devise Inactive")
    session        Int      @map("Session")
    dateCreation   DateTime @map("Date Creation")
    rowVer         Bytes?   @map("RowVer")

    tUtilisateurs     TUtilisateurs       @relation(fields: [session], references: [id])
    tPays             TPays[]
    tColisageDossiers TColisageDossiers[]
    tTauxChange       TTauxChange[]

    @@map("TDevises")
}

/// Countries
model TPays {
    id           Int      @id @default(autoincrement()) @map("ID Pays")
    codePays     String   @unique @map("Code Pays") @db.NVarChar(5)
    libellePays  String   @unique @map("Libelle Pays") @db.NVarChar(200)
    deviseLocale Int      @map("Devise Locale")
    session      Int      @map("Session")
    dateCreation DateTime @map("Date Creation")
    rowVer       Bytes?   @map("RowVer")

    tDevises          TDevises            @relation(fields: [deviseLocale], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tUtilisateurs     TUtilisateurs       @relation(fields: [session], references: [id])
    tEntites          TEntites[]
    tColisageDossiers TColisageDossiers[]

    @@map("TPays")
}

/// Entity groups
model TGroupesEntites {
    id              Int      @id @default(autoincrement()) @map("ID Groupe Entite")
    nomGroupeEntite String   @unique @map("Nom Groupe Entite") @db.NVarChar(200)
    session         Int      @map("Session")
    dateCreation    DateTime @map("Date Creation")
    rowVer          Bytes?   @map("RowVer")

    tUtilisateurs TUtilisateurs @relation(fields: [session], references: [id])
    tEntites      TEntites[]

    @@map("TGroupesEntites")
}

/// Business entities
model TEntites {
    id           Int      @id @default(autoincrement()) @map("ID Entite")
    codeEntite   String   @map("Code Entite") @db.NVarChar(10)
    nomEntite    String   @unique @map("Nom Entite") @db.NVarChar(200)
    groupeEntite Int      @map("Groupe Entite")
    pays         Int      @map("Pays")
    session      Int      @map("Session")
    dateCreation DateTime @map("Date Creation")
    rowVer       Bytes?   @map("RowVer")

    tGroupesEntites TGroupesEntites @relation(fields: [groupeEntite], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tPays           TPays           @relation(fields: [pays], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tUtilisateurs   TUtilisateurs   @relation(fields: [session], references: [id])
    tBranches       TBranches[]
    tClients        TClients[]
    tConvertions    TConvertions[]

    @@map("TEntites")
}

/// Entity branches
model TBranches {
    id           Int      @id @default(autoincrement()) @map("ID Branche")
    codeBranche  String   @unique @map("Code Branche") @db.NVarChar(20)
    nomBranche   String   @unique @map("Nom Branche") @db.NVarChar(200)
    entite       Int      @map("Entite")
    session      Int      @map("Session")
    dateCreation DateTime @map("Date Creation")
    rowVer       Bytes?   @map("RowVer")

    tEntites      TEntites      @relation(fields: [entite], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tUtilisateurs TUtilisateurs @relation(fields: [session], references: [id])
    tDossiers     TDossiers[]

    @@map("TBranches")
}

/// Packing details for folders
model TColisageDossiers {
    id                  Int      @id @default(autoincrement()) @map("ID Colisage Dossier")
    dossier             Int      @map("Dossier")
    hsCode              Int?     @map("HS Code")
    descriptionColis    String   @map("Description Colis") @db.NVarChar(1000)
    noCommande          String   @map("No Commande") @db.NVarChar(50)
    nomFournisseur      String   @map("Nom Fournisseur") @db.NVarChar(200)
    noFacture           String   @map("No Facture") @db.NVarChar(50)
    itemNo              String   @map("Item No") @db.NVarChar(50)
