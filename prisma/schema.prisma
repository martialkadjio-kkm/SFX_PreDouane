/// Harmonized System product codes
model THSCodes {
    id            Int      @id @default(autoincrement()) @map("ID HS Code")
    hsCode        String   @map("HS Code") @db.NVarChar(50)
    libelleHSCode String   @map("Libelle HS Code") @db.NVarChar(200)
    entite        Int      @map("Entite")
    session       Int      @map("Session")
    dateCreation  DateTime @map("Date Creation")
    rowVer        Bytes?   @map("RowVer")

    tColisageDossiers TColisageDossiers[]

    @@unique([hsCode, entite], name: "UQ_THSCodes_HS_Code")
    @@map("THSCodes")
}

/// Declaration note details with regime splitting
model TNotesDetail {
    id              Int      @id @default(autoincrement()) @map("ID Note Detail")
    colisageDossier Int      @map("Colisage Dossier")
    regime          String   @map("Regime") @db.NVarChar(10)
    nbrePaquetage   Decimal  @map("Nbre Paquetage") @db.Decimal(24, 2)
    qteColis        Decimal  @default(0) @map("Qte Colis") @db.Decimal(24, 2)
    valeur          Decimal  @map("Valeur") @db.Decimal(24, 2)
    basePoidsBrut   Decimal  @map("Base Poids Brut") @db.Decimal(24, 2)
    basePoidsNet    Decimal  @map("Base Poids Net") @db.Decimal(24, 2)
    baseVolume      Decimal  @map("Base Volume") @db.Decimal(24, 2)
    session         Int      @map("Session")
    dateCreation    DateTime @map("Date Creation")
    rowVer          Bytes?   @map("RowVer")

    tColisageDossiers TColisageDossiers @relation(fields: [colisageDossier], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tUtilisateurs     TUtilisateurs     @relation(fields: [session], references: [id])

    @@map("TNotesDetail")
}

/// User roles
model TRoles {
    id           Int      @id @default(autoincrement()) @map("ID Role")
    libelleRole  String   @unique @map("Libelle Role") @db.NVarChar(200)
    session      Int      @map("Session")
    dateCreation DateTime @map("Date Creation")
    rowVer       Bytes?   @map("RowVer")

    tUtilisateurs      TUtilisateurs        @relation(fields: [session], references: [id])
    tRolesUtilisateurs TRolesUtilisateurs[]
    tPermissonsRoles   TPermissonsRoles[]

    @@map("TRoles")
}

/// System permissions
model TPermissionsBase {
    id                Int       @id @default(autoincrement()) @map("ID Permission Base")
    libellePermission String    @unique @map("Libelle Permission") @db.NVarChar(200)
    permissionActive  Boolean   @default(true) @map("Permission Active")
    dateActivation    DateTime? @map("Date Activation")
    rowVer            Bytes?    @map("RowVer")

    tPermissonsRoles TPermissonsRoles[]
    tutilisateurs    TUtilisateurs?     @relation(fields: [tUtilisateursId], references: [id])
    tUtilisateursId  Int?

    @@map("TPermissionsBase")
}

/// User-role assignments
model TRolesUtilisateurs {
    id           Int      @id @default(autoincrement()) @map("ID Role Utilisateur")
    role         Int      @map("Role")
    utilisateur  Int      @map("Utilisateur")
    session      Int      @map("Session")
    dateCreation DateTime @map("Date Creation")
    rowVer       Bytes?   @map("RowVer")

    tRoles        TRoles        @relation(fields: [role], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tUtilisateurs TUtilisateurs @relation(fields: [utilisateur], references: [id])

    @@map("TRolesUtilisateurs")
}

/// Role-permission mappings
model TPermissonsRoles {
    id           Int      @id @default(autoincrement()) @map("ID Permission Role")
    role         Int      @map("Role")
    permission   Int      @map("Permission")
    session      Int      @map("Session")
    dateCreation DateTime @map("Date Creation")
    rowVer       Bytes?   @map("RowVer")

    tRoles           TRoles           @relation(fields: [role], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tPermissionsBase TPermissionsBase @relation(fields: [permission], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tUtilisateurs    TUtilisateurs    @relation(fields: [session], references: [id])

    @@map("TPermissonsRoles")
}

/// Customs regimes
model TRegimesDouaniers {
    id                    Int      @id @default(autoincrement()) @map("ID Regime Douanier")
    codeRegimeDouanier    String   @unique @map("Code Regime Douanier") @db.NVarChar(10)
    libelleRegimeDouanier String   @unique @map("Libelle Regime Douanier") @db.NVarChar(200)
    session               Int      @map("Session")
    dateCreation          DateTime @map("Date Creation")
    rowVer                Bytes?   @map("RowVer")

    tUtilisateurs        TUtilisateurs          @relation(fields: [session], references: [id])
    tRegimesDeclarations TRegimesDeclarations[]

    @@map("TRegimesDouaniers")
}

/// Declaration regimes with DC/TR ratios
model TRegimesDeclarations {
    id                       Int      @id @default(autoincrement()) @map("ID Regime Declaration")
    regimeDouanier           Int      @map("Regime Douanier")
    libelleRegimeDeclaration String   @unique @map("Libelle Regime Declaration") @db.NVarChar(200)
    tauxRegime               Decimal  @map("Taux Regime") @db.Decimal(24, 3)
    entite                   Int      @map("Entite")
    session                  Int      @map("Session")
    dateCreation             DateTime @map("Date Creation")
    rowVer                   Bytes?   @map("RowVer")

    tRegimesDouaniers TRegimesDouaniers   @relation(fields: [regimeDouanier], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tUtilisateurs     TUtilisateurs       @relation(fields: [session], references: [id])
    tColisageDossiers TColisageDossiers[]
    tRegimesClients   TRegimesClients[]

    @@map("TRegimesDeclarations")
}

/// Client-specific declaration regimes
model TRegimesClients {
    id                Int      @id @default(autoincrement()) @map("ID Regime Client")
    client            Int      @map("Client")
    regimeDeclaration Int      @map("Regime Declaration")
    session           Int      @map("Session")
    dateCreation      DateTime @map("Date Creation")
    rowVer            Bytes?   @map("RowVer")

    tClients             TClients             @relation(fields: [client], references: [id], onDelete: NoAction, onUpdate: NoAction)
