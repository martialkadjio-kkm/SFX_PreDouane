    tUtilisateurs        TUtilisateurs        @relation(fields: [session], references: [id])

    @@map("TRegimesClients")
}

/// Exchange rates
model TTauxChange {
    id           Int      @id @default(autoincrement()) @map("ID Taux Change")
    convertion   Int      @map("Convertion")
    devise       Int      @map("Devise")
    tauxChange   Decimal  @map("Taux Change") @db.Decimal(24, 6)
    session      Int      @map("Session")
    dateCreation DateTime @map("Date Creation")
    rowVer       Bytes?   @map("RowVer")

    tConvertions  TConvertions  @relation(fields: [convertion], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tDevises      TDevises      @relation(fields: [devise], references: [id], onDelete: NoAction, onUpdate: NoAction)
    tUtilisateurs TUtilisateurs @relation(fields: [session], references: [id])

    @@unique([convertion, devise], name: "UQ_TTauxChange_Convertion_Devise")
    @@map("TTauxChange")
}

