generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["views"]
    output          = "../src/generated/prisma"
}

datasource db {
    provider = "sqlserver"
    url      = env("DATABASE_URL")
}

// ============================================================================
// CORE TABLES (27 total)
